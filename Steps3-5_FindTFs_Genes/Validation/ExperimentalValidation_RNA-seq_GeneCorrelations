  sub <- exactTable[exactTable$freq_quartile %in% pr, ]
  
  tab <- table(
    factor(sub$freq_quartile),
    factor(sub$sig, levels = c(FALSE, TRUE))
  )
  
  # safety check
  if (nrow(tab) < 2 || any(rowSums(tab) == 0)) {
    return(data.frame(
      group1 = pr[1],
      group2 = pr[2],
      p_value = NA
    ))
  }
  
  test <- prop.test(tab[, "TRUE"], rowSums(tab), correct = FALSE)
  
  data.frame(
    group1 = pr[1],
    group2 = pr[2],
    p_value = test$p.value
  )
}))

